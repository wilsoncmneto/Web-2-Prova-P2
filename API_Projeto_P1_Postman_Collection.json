    {
      "name": "04 - CRUD Produto",
      "item": [
        {
          "name": "Criar Produto Temporario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Produto Teste Postman {{$timestamp}}\",\n  \"slug\": \"produto-teste-postman-{{$timestamp}}\",\n  \"description\": \"Produto criado apenas para teste no Postman\",\n  \"price\": 99.9,\n  \"productSituationId\": 1,\n  \"productCategoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/produtos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "produtos"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Produto criado', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('produtoId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Buscar Produto Criado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "produtos",
                "{{produtoId}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar Produto Criado",
          "request": {
            "method": "PUT",
