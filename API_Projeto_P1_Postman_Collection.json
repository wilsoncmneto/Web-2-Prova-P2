              "raw": "{\n  \"description\": \"Produto temporario atualizado no Postman\",\n  \"price\": 109.9\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
